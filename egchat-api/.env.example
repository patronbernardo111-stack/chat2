# ══════════════════════════════════════════════════════════════════
# EGCHAT API - Variables de entorno
# Copia este archivo como .env y rellena los valores
# En Render: añade estas variables en Settings > Environment
# ══════════════════════════════════════════════════════════════════

# Puerto (Render lo asigna automáticamente)
PORT=5000

# JWT Secret (cambia por una cadena aleatoria segura)
JWT_SECRET=egchat_super_secret_key_2026_cambiar_esto

# Supabase (obtén estos valores en tu proyecto Supabase > Settings > API)
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...TU_SERVICE_ROLE_KEY
