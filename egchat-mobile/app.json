 {
  "expo": {
    "name": "EGCHAT",
    "slug": "egchat",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.egchat.app",
      "supportsTablet": false
    },
    "android": {
      "package": "com.egchat.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_FULL_SCREEN_INTENT",
        "POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "EGCHAT necesita la camara para fotos de perfil."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "EGCHAT necesita tu ubicacion para servicios de taxi."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00c8a0",
          "defaultChannel": "egchat-messages",
          "sounds": [
            "./assets/notification.wav"
          ]
        }
      ]
    ],
    "web": {
      "bundler": "webpack",
      "output": "single"
    },
    "scheme": "egchat",
    "extra": {
      "apiUrl": "https://chat2-0x2c.onrender.com",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "6200ec00-54d7-4ef4-a348-56e80a1452f6"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "reddington120"
  }
}
