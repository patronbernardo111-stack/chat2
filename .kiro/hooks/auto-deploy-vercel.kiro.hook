{
  "enabled": true,
  "name": "Auto Deploy a Vercel (con fallback a Netlify)",
  "description": "Ejecuta deploy-auto.ps1 — push a git, asigna alias en Vercel, y si Vercel tiene limite alcanzado hace fallback a Netlify.",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "powershell -ExecutionPolicy Bypass -File deploy-auto.ps1",
    "timeout": 420
  }
}
