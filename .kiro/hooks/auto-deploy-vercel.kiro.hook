{
  "enabled": true,
  "name": "Auto Deploy a Vercel",
  "description": "Hace build y deploy automático a Vercel producción cuando el agente termina de hacer cambios en el código",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "npm run build && vercel --prod --yes",
    "timeout": 300
  }
}