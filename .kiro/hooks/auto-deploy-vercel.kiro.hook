{
  "enabled": true,
  "name": "Auto Deploy a Vercel",
  "description": "Hace build y push a git — Vercel despliega automáticamente desde GitHub sin consumir el límite de la CLI",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "npm run build && git add -A && git diff --cached --quiet || git commit -m \"deploy: auto build and push\" && git push",
    "timeout": 300
  }
}