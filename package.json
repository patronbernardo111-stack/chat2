{
    "name": "egchat-frontend",
    "version": "2.5.2",
    "description": "EGCHAT Frontend - Complete Enterprise Platform - v2.5 Production Release",
    "type": "module",
    "scripts": {
        "start": "node server.js",
        "dev": "vite --port=3001",
        "build": "vite build",
        "build:pwa": "vite build --config vite.config.pwa.ts",
        "preview": "vite preview",
        "preview:pwa": "vite preview --port=3001 --host",
        "clean": "rm -rf dist",
        "lint": "tsc --noEmit",
        "electron": "electron electron.js",
        "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3001 && cross-env NODE_ENV=development npm run electron\"",
        "deploy:pwa": "npm run build:pwa && vercel --prod",
        "deploy": "npm run build && vercel --prod",
        "deploy:auto": "powershell -ExecutionPolicy Bypass -File deploy-auto.ps1",
        "deploy:auto:sh": "bash deploy-auto.sh"
    },
    "dependencies": {
        "@google/genai": "^1.29.0",
        "@maptiler/sdk": "^4.0.1",
        "@supabase/supabase-js": "^2.35.0",
        "@tailwindcss/vite": "^4.1.14",
        "@types/leaflet": "1.9.21",
        "@types/qrcode": "^1.5.6",
        "@vitejs/plugin-react": "^5.0.4",
        "bcryptjs": "^2.4.3",
        "better-sqlite3": "^12.4.1",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^4.21.2",
        "framer-motion": "^12.35.2",
        "jsonwebtoken": "^9.0.2",
        "leaflet": "1.9.4",
        "lucide-react": "^0.546.0",
        "motion": "^12.23.24",
        "qrcode": "^1.5.4",
        "qrcode.react": "^4.2.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tesseract.js": "^7.0.0",
        "vite": "^6.2.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^22.14.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "autoprefixer": "^10.4.21",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^41.0.3",
        "tailwindcss": "^4.1.14",
        "terser": "^5.46.1",
        "tsx": "^4.21.0",
        "typescript": "~5.8.2",
        "vercel": "^51.5.0",
        "vite": "^6.2.0",
        "wait-on": "^9.0.4"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/egchat/frontend.git"
    },
    "bugs": {
        "url": "https://github.com/egchat/frontend/issues"
    },
    "homepage": "https://egchat-app.vercel.app",
    "deployment": {
        "vercel": {
            "url": "https://egchat-app.vercel.app",
            "service": "web",
            "buildCommand": "npm run build:pwa",
            "startCommand": "npm run preview:pwa"
        }
    }
}
